pipeline/media.json
# Track card/banner image + video-clip files (referenced by axbrief-data.js) but
# ignore any other build junk that lands under pipeline/media/. Note: the raw
# downloaded source clips (<id>.src.*) stay ignored — only the encoded outputs
# (<id>.mp4 / <id>.webm) and stills are tracked.
pipeline/media/**
!pipeline/media/**/
!pipeline/media/**/*.jpg
!pipeline/media/**/*.jpeg
!pipeline/media/**/*.png
!pipeline/media/**/*.svg
!pipeline/media/**/*.webp
!pipeline/media/**/*.mp4
!pipeline/media/**/*.webm
pipeline/media/**/*.src.*
pipeline/runs/

.DS_Store
**/.DS_Store
.playwright-mcp/
